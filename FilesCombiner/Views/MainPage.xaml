<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FilesCombiner.Views.MainPage"
             Title="Files Combiner">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
          Padding="20"
          RowSpacing="10">

        <!-- Title -->
        <Label Text="Files Combiner"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Grid.Row="0"/>

        <!-- Root Directory Selection -->
        <Grid ColumnDefinitions="*,Auto"
              Grid.Row="1">
            <Entry Placeholder="Select root directory..."
                   Text="{Binding RootDirectory}"
                   IsReadOnly="True"/>
            <Button Text="Browse"
                    Command="{Binding SelectRootDirectoryCommand}"
                    Grid.Column="1"
                    Margin="5,0,0,0"/>
        </Grid>

        <!-- Output Directory Selection -->
        <Grid ColumnDefinitions="*,Auto"
              Grid.Row="2">
            <Entry Placeholder="Select output directory..."
                   Text="{Binding OutputDirectory}"
                   IsReadOnly="True"/>
            <Button Text="Browse"
                    Command="{Binding SelectOutputDirectoryCommand}"
                    Grid.Column="1"
                    Margin="5,0,0,0"/>
        </Grid>

        <!-- Whitelist Pattern -->
        <VerticalStackLayout Grid.Row="3"
                             Spacing="5">
            <Label Text="Whitelist Pattern (e.g., *.txt;*.cs)"
                   FontSize="14"/>
            <Entry Placeholder="*.txt;*.cs;*.xml"
                   Text="{Binding WhitelistPattern}"/>
        </VerticalStackLayout>

        <!-- Blacklist Pattern -->
        <!-- Single Blacklist Field (like .gitignore) -->
        <VerticalStackLayout Grid.Row="4"
                     Spacing="5">
            <Label Text="Blacklist Pattern (like .gitignore - one pattern per line)"
           FontSize="14"/>
            <Editor Placeholder="# Lines starting with # are comments
*.log
*.tmp
bin/
obj/
.git/
node_modules/
.DS_Store
Thumbs.db
**/Debug/
**/Release/"
            Text="{Binding BlacklistPattern}"
            HeightRequest="200"
            AutoSize="TextChanges"/>
            <Label Text="Supports .gitignore syntax: *, **, !, /, and directory ending with /"
           FontSize="10"
           TextColor="Gray"/>
        </VerticalStackLayout>

        <!-- Settings Buttons -->
        <Grid ColumnDefinitions="*,*"
              Grid.Row="5"
              ColumnSpacing="10">
            <Button Text="Save Settings"
                    Command="{Binding SaveSettingsCommand}"
                    BackgroundColor="#4CAF50"/>
            <Button Text="Load Settings"
                    Command="{Binding LoadSettingsCommand}"
                    BackgroundColor="#2196F3"
                    Grid.Column="1"/>
        </Grid>

        <!-- Combine Button -->
        <Button Text="Combine Files"
                Command="{Binding CombineFilesCommand}"
                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                BackgroundColor="#FF9800"
                FontSize="16"
                FontAttributes="Bold"
                Grid.Row="6"/>

        <!-- Status -->
        <Label Text="{Binding StatusMessage}"
               FontSize="12"
               TextColor="Gray"
               HorizontalOptions="Center"
               Grid.Row="7"/>

        <!-- Processed Files List -->
        <CollectionView ItemsSource="{Binding ProcessedFiles}"
                        Grid.Row="8"
                        IsVisible="{Binding IsProcessing}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding}"
                           FontSize="10"
                           LineBreakMode="TailTruncation"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Indicator -->
        <ActivityIndicator IsRunning="{Binding IsProcessing}"
                           IsVisible="{Binding IsProcessing}"
                           Grid.Row="8"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

    </Grid>
</ContentPage>